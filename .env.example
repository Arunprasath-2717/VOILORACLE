# ═══════════════════════════════════════════════════════════════
# VEILORACLE — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Most features work WITHOUT any API keys (RSS feeds + sample data).

# NewsAPI Key (optional, free tier: https://newsapi.org)
# Without this, the system uses RSS feeds and sample data.
NEWSAPI_KEY=

# Newsdata.io API Key (optional, free tier: https://newsdata.io)
NEWSDATA_API_KEY=

# Google Gemini API Key (optional, for AI chat / event labeling)
GEMINI_API_KEY=

# Hugging Face API Token (optional, for large model inference)
# Get yours at: https://huggingface.co/settings/tokens
# Required for: Qwen2, Mistral, DeepSeek, Llama-3 (7B+ models)
# Without this, the system uses intelligent rule-based fallback analysis
HF_API_TOKEN=

# ═══════════════════════════════════════════════════════════════
# AI ENGINES — Most run locally, no external API keys needed!
# ═══════════════════════════════════════════════════════════════
#
# CORE NLP MODELS (auto-downloaded, run locally):
#   1. sentence-transformers/all-MiniLM-L6-v2  — Event similarity & clustering
#   2. cardiffnlp/twitter-roberta-base-sentiment — Sentiment analysis
#   3. spaCy en_core_web_sm                    — Named entity recognition
#   4. BART (facebook/bart-large-cnn)          — Text summarization
#   5. NLTK (punkt, stopwords)                 — Text preprocessing
#
# SECTOR-SPECIFIC AI MODELS:
#   6. ProsusAI/finbert           — Finance (runs locally)
#   7. microsoft/BioGPT-Large     — Health (runs locally)
#   8. Qwen/Qwen2-7B-Instruct    — Technology (HF API or fallback)
#   9. mistralai/Mistral-7B-Instruct — Politics (HF API or fallback)
#  10. deepseek-ai/deepseek-llm-7b-chat — Business (HF API or fallback)
#  11. meta-llama/Llama-3-8B-Instruct   — General (HF API or fallback)
#
# ANALYSIS ENGINES (no config needed):
#  12. DBSCAN Clustering           — scikit-learn
#  13. Impact Prediction           — rule-based sector matching
#  14. Anomaly Detection           — numpy z-score analysis
#  15. Trend Forecasting           — numpy linear regression
